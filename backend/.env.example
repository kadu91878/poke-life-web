SECRET_KEY=django-insecure-troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Redis ─────────────────────────────────────────────────────────────────
# URL de conexão ao Redis.
# Deixe vazio para desabilitar Redis (operação sem Redis é suportada).
# Desenvolvimento local:  redis://localhost:6379/0
# Produção:               redis://user:password@host:6379/0
#
# Usos do Redis neste projeto:
#   1. Channel Layer     — pub/sub para WebSockets (multi-processo)
#   2. Session activity  — TTL automático de 24 h por sala ativa
#   3. Lock distribuído  — exclusão mútua entre workers Daphne
#
# Consumo estimado: < 7 MB (muito abaixo do limite de 50 MB de produção)
REDIS_URL=redis://localhost:6379/0

# Channel Layer: 'memory' para dev local (processo único), 'redis' para produção
# Use 'redis' sempre que houver mais de um processo Daphne/Uvicorn.
CHANNEL_LAYERS_BACKEND=memory

# ── Banco de dados ────────────────────────────────────────────────────────
# Caminho do banco SQLite (opcional — padrão: backend/db.sqlite3)
SQLITE_PATH=db.sqlite3

# ── CORS ──────────────────────────────────────────────────────────────────
# URLs do frontend permitidas (separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
